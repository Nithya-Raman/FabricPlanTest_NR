expression TBD_DateCal = ```
		let
		    // Create a list of dates from January 1, 2022 to December 31, 2028
		    StartDate = #date(2022, 1, 1),
		    EndDate = #date(2028, 12, 31),
		    DateList = List.Dates(StartDate, Duration.Days(EndDate - StartDate) + 1, #duration(1, 0, 0, 0)),
		    
		    // Convert the list of dates to a table
		    DateTable = Table.FromList(DateList, Splitter.SplitByNothing(), {"Date"}, null, ExtraValues.Error),
		    
		    // Add custom columns
		    AddYear = Table.AddColumn(DateTable, "Year", each Date.Year([Date])),
		    AddMonth = Table.AddColumn(AddYear, "Month", each Date.ToText([Date], "MMMM")),
		    AddMonthNumber = Table.AddColumn(AddMonth, "MonthNumber", each Date.Month([Date])),
		    AddDay = Table.AddColumn(AddMonthNumber, "Day", each Date.Day([Date])),
		    AddQuarter = Table.AddColumn(AddDay, "Quarter", each "Q" & Number.ToText(Date.QuarterOfYear([Date]))),
		    AddWeekday = Table.AddColumn(AddQuarter, "Weekday", each Date.ToText([Date], "dddd")),
		    AddIsWeekday = Table.AddColumn(AddWeekday, "IsWeekday", each if Date.DayOfWeek([Date], Day.Sunday) >= 1 and Date.DayOfWeek([Date], Day.Sunday) <= 5 then true else false),
		    #"Changed Type" = Table.TransformColumnTypes(AddIsWeekday,{{"Date", type datetime}}),
		    #"Merged Queries" = Table.NestedJoin(#"Changed Type", {"Date"}, SourceDate, {"Datekey"}, "SourceDate", JoinKind.RightOuter),
		    #"Expanded SourceDate" = Table.ExpandTableColumn(#"Merged Queries", "SourceDate", {"IsWorkDay", "IsHoliday", "HolidayName", "EuropeSeason", "NorthAmericaSeason", "AsiaSeason"}, {"IsWorkDay", "IsHoliday", "HolidayName", "EuropeSeason", "NorthAmericaSeason", "AsiaSeason"}),
		    #"Added Custom" = Table.AddColumn(#"Expanded SourceDate", "IsWeekDaySource", each if [IsWorkDay] = "WeekEnd" then false else true),
		    #"Reordered Columns" = Table.ReorderColumns(#"Added Custom",{"Date", "Year", "Month", "MonthNumber", "Day", "Quarter", "Weekday", "IsWeekday", "IsWeekDaySource", "IsWorkDay", "IsHoliday", "HolidayName", "EuropeSeason", "NorthAmericaSeason", "AsiaSeason"}),
		    Custom1 = Table.AddColumn(#"Reordered Columns", "IsWeekDayMatch", each if [IsWeekday] = [IsWeekDaySource] then 1 else 0),
		    #"Filtered Rows" = Table.SelectRows(Custom1, each ([IsWeekDayMatch] = 0))
		in
		    #"Filtered Rows"
		```
	lineageTag: 2e06b96b-1476-46c1-8763-b5c1eac8d4cc
	queryGroup: 'Date Cal'

