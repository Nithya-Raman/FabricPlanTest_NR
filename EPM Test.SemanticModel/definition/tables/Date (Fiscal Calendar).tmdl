	partition 'Date (Fiscal Calendar)' = calculated
		mode: import
		source = ```
				
				//************** Script developed by RADACAD - edition: July 2021 
				//************** set the variables below for your custom date table setting 
				var _fromYear=2022 
				var _toYear=2028
				var _startOfFiscalYear=4 
				//************** 
				var _today=TODAY()
				return
				ADDCOLUMNS(
				    CALENDAR(
				        DATE(_fromYear,1,1),
				        DATE(_toYear,12,31)
				    ),
				    
				    "End of Week",[Date]+7-WEEKDAY([Date]),
				
				    "Fiscal Year", 
				        IF(MONTH([Date]) >= _startOfFiscalYear, YEAR([Date]) + 1, YEAR([Date])),
				
				    "Fiscal Quarter", 
				        RIGHT(IF(MONTH([Date]) >= _startOfFiscalYear, YEAR([Date]) + 1, YEAR([Date])),2) & 
				        "-Q" &
				        SWITCH(
				            TRUE(),
				            MONTH([Date]) >= 4 && MONTH([Date]) <= 6, 1,
				            MONTH([Date]) >= 7 && MONTH([Date]) <= 9, 2,
				            MONTH([Date]) >= 10 && MONTH([Date]) <= 12, 3,
				            MONTH([Date]) >= 1 && MONTH([Date]) <= 3, 4
				        ),
				
				    "Fiscal Quarter Short", 
				        "Qtr " &
				        SWITCH(
				            TRUE(),
				            MONTH([Date]) >= 4 && MONTH([Date]) <= 6, 1,
				            MONTH([Date]) >= 7 && MONTH([Date]) <= 9, 2,
				            MONTH([Date]) >= 10 && MONTH([Date]) <= 12, 3,
				            MONTH([Date]) >= 1 && MONTH([Date]) <= 3, 4
				        ),
				
				    "Fiscal Month", RIGHT(YEAR([Date]),2) & "-" & FORMAT([Date], "MMM"),
				
				    "Fiscal Month Short", FORMAT([Date], "MMM"),
				
				    "Fiscal Month Number", 
				        SWITCH(
				            MONTH([Date]),
				            4, 1, 5, 2, 6, 3, 7, 4, 8, 5, 9, 6, 
				            10, 7, 11, 8, 12, 9, 1, 10, 2, 11, 3, 12
				        ),
				
				    "YearMonth Sort", 
				        IF(MONTH([Date]) >= _startOfFiscalYear, YEAR([Date]) + 1, YEAR([Date])) * 100 + 
				        SWITCH(
				            MONTH([Date]),
				            4, 1, 5, 2, 6, 3, 7, 4, 8, 5, 9, 6, 
				            10, 7, 11, 8, 12, 9, 1, 10, 2, 11, 3, 12
				        ),
				
				    //-----------------------------------------
				    // NEW COLUMNS
				    //-----------------------------------------
				
				    // Fiscal Year with Prefix → FY2025
				    "Fiscal Year with Prefix",
				        "FY" & 
				        IF(MONTH([Date]) >= _startOfFiscalYear, YEAR([Date]) + 1, YEAR([Date])),
				
				    // QuarterV2 → Q1, Q2, Q3, Q4 (Fiscal)
				    "QuarterV2",
				        "Q" &
				        SWITCH(
				            TRUE(),
				            MONTH([Date]) >= 4 && MONTH([Date]) <= 6, 1,
				            MONTH([Date]) >= 7 && MONTH([Date]) <= 9, 2,
				            MONTH([Date]) >= 10 && MONTH([Date]) <= 12, 3,
				            MONTH([Date]) >= 1 && MONTH([Date]) <= 3, 4
				        )
				)
				
				```

